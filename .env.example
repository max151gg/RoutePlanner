# Browser + general key (Maps JS, Geocoding, Routes). Used for local dev.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Optional server-side key for Places API (Autocomplete/Details) calls made by
# the backend. If omitted, the app falls back to GOOGLE_MAPS_API_KEY locally.
# Never exposed to the browser.
GOOGLE_MAPS_SERVER_KEY=your_google_maps_server_key_here
